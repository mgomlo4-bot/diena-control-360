# DIENA CONTROL 360 - Variables de entorno
# Copiar este archivo como .env.local en desarrollo.
# Configurar las mismas variables en el entorno de despliegue.

# Base de datos PostgreSQL usada por Prisma.
# Ejemplo local:
# DATABASE_URL="postgresql://usuario:password@localhost:5432/diena_control_360?schema=public"
# Ejemplo Supabase/Neon/Railway: usar la URL PostgreSQL proporcionada por el proveedor.
DATABASE_URL="postgresql://usuario:password@localhost:5432/diena_control_360?schema=public"

# Token largo para crear el primer administrador en /setup.
# Debe tener al menos 32 caracteres y no debe subirse nunca con valor real.
INITIAL_ADMIN_TOKEN="CAMBIAR_POR_TOKEN_LARGO_DE_AL_MENOS_32_CARACTERES"

# Modo de datos de la web app.
# database = usa API/Prisma/PostgreSQL.
# localStorage = solo prototipo local del navegador.
NEXT_PUBLIC_DATA_SOURCE_MODE="database"

# Recomendado en producción/despliegue.
NEXT_TELEMETRY_DISABLED=1