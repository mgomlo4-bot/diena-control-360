// Prisma schema for DIENA CONTROL 360

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enumerations

enum EstadoHito {
  PENDIENTE
  EN_CURSO
  COMPLETADO
  VENCIDO
  BLOQUEADO
  ANULADO
}

enum EstadoTarea {
  PENDIENTE
  EN_CURSO
  FINALIZADA
  BLOQUEADA
  ANULADA
  CURSO_EMPEZADO
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoInstancia {
  PENDIENTE
  PENDIENTE_DE_INFORME
  EN_TRAMITE
  CONTESTADA
  FINALIZADA
  FUERA_DE_PLAZO
  BLOQUEADA
  ARCHIVADA
}

enum EstadoImportacion {
  SUBIDO
  PREVISUALIZADO
  VALIDADO
  CON_ADVERTENCIAS
  CARGADO_STAGING
  CONFIRMADO
  ERROR
  CANCELADO
}

enum EstadoFilaImportacion {
  VALIDA
  DUPLICADA
  ADVERTENCIA
  RECHAZADA
  IMPORTADA
}

// Models

model Responsable {
  id            Int      @id @default(autoincrement())
  nombre        String
  empleo        String?  // empleo militar o cargo
  rolApp        String?  // rol en la app (gestor, administrador, etc.)
  unidad        String?
  email         String?
  telefono      String?
  activo        Boolean  @default(true)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Relaciones
  cursos        Curso[]
  cursoHitos    CursoHito[]
  instancias    Instancia[]
  tareas        TareaOperativa[]
  documentos    Documento[]
  auditorias    AuditoriaEstadoCurso[]
  conversacion  ConversacionAsistente[]
}

model CentroOrganismo {
  id            Int      @id @default(autoincrement())
  nombre        String
  sigla         String?
  tipo          String?
  localidad     String?
  contacto      String?
  email         String?
  telefono      String?
  observaciones String?
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cursos        Curso[]
  instancias    Instancia[]
}

model EstadoCurso {
  id      Int    @id @default(autoincrement())
  orden   Int
  codigo  String
  nombre  String
  descripcion String?
  color   String?
  activo  Boolean @default(true)
  cursos  Curso[]
}

model Curso {
  id                           Int      @id @default(autoincrement())
  codigoCurso                  String   @unique
  nombreCurso                  String
  tipoCurso                    String?
  categoriaOperativa           String?
  estadoCursoId                Int
  estadoCurso                  EstadoCurso @relation(fields: [estadoCursoId], references: [id])
  escuelaCentroId              Int?
  escuelaCentro                CentroOrganismo? @relation(fields: [escuelaCentroId], references: [id])
  responsableId                Int?
  responsable                  Responsable? @relation(fields: [responsableId], references: [id])
  mesComienzo                  Int?
  anio                         Int?
  fechaInicioDistancia         DateTime?
  fechaFinDistancia            DateTime?
  fechaExamenPrevio            DateTime?
  fechaInicioPresencial        DateTime?
  fechaFinPresencial           DateTime?
  fechaInicio                  DateTime?
  fechaFin                     DateTime?
  activo                       Boolean   @default(true)
  activado                     Boolean   @default(false)
  requierePruebasFisicas       Boolean   @default(false)
  requiereReconocimientoMedico Boolean   @default(false)
  alumnosNombrados             Int?      @default(0)
  alumnosBaja                  Int?      @default(0)
  alumnosEgresados             Int?      @default(0)
  mujeresEgresadas             Int?      @default(0)
  bodConvocatoria              String?
  bodNombramiento             String?
  bodFinalizacion             String?
  fechaPublicacionBodFinalizacion DateTime?
  situacionAdministrativaFinal String?
  observaciones                String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  // Relaciones
  hitos                        CursoHito[]
  instancias                   Instancia[]
  tareas                       TareaOperativa[]
  documentos                   Documento[]
  auditoria                    AuditoriaEstadoCurso[]
  conversacion                 ConversacionAsistente[]
}

model PlantillaHito {
  id                 Int      @id @default(autoincrement())
  categoriaOperativa String?
  orden              Int?
  codigoHito         String?
  nombreHito         String
  descripcion        String?
  offsetDias         Int?    // Días respecto a la fecha de referencia (negativo para antes, positivo para después)
  referenciaFecha    String? // nombre del campo al que se refiere, por ejemplo: fechaInicio, fechaFin
  obligatorio        Boolean @default(false)
  activo             Boolean @default(true)
  hitos              CursoHito[]
}

model CursoHito {
  id             Int         @id @default(autoincrement())
  cursoId        Int
  plantillaHitoId Int?
  curso          Curso       @relation(fields: [cursoId], references: [id])
  plantillaHito  PlantillaHito? @relation(fields: [plantillaHitoId], references: [id])
  nombreHito     String
  tipoHito       String?
  fechaPrevista  DateTime?
  fechaReal      DateTime?
  estadoHito     EstadoHito @default(PENDIENTE)
  responsableId  Int?
  responsable    Responsable? @relation(fields: [responsableId], references: [id])
  diasRetraso    Int?      @default(0)
  prioridad      Int?      // Puede ser un número para ordenar, sustituible por enumeración
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Instancia {
  id                 Int            @id @default(autoincrement())
  numeroInterno      String?
  codigoReferencia   String?
  asunto             String
  interesado         String
  empleoInteresado   String?
  dniInteresado      String?
  unidad             String?
  tipoInstancia      String?
  sRef               String?
  nRef               String?
  fechaEntrada       DateTime?
  plazoDias          Int?
  fechaLimite        DateTime?
  estadoInstancia    EstadoInstancia @default(PENDIENTE)
  solicitaInforme    Boolean        @default(false)
  organoInformanteId Int?
  organoInformante   CentroOrganismo? @relation(fields: [organoInformanteId], references: [id])
  cursoId            Int?
  curso              Curso?         @relation(fields: [cursoId], references: [id])
  responsableId      Int?
  responsable        Responsable?    @relation(fields: [responsableId], references: [id])
  resultado          String?
  observaciones      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tareas             TareaOperativa[]
  documentos         Documento[]
  conversacion       ConversacionAsistente[]
}

model TareaOperativa {
  id             Int           @id @default(autoincrement())
  titulo         String
  descripcion    String?
  accion         String?
  estadoTarea    EstadoTarea  @default(PENDIENTE)
  prioridad      PrioridadTarea @default(MEDIA)
  responsableId  Int?
  responsable    Responsable?   @relation(fields: [responsableId], references: [id])
  cursoId        Int?
  curso          Curso?        @relation(fields: [cursoId], references: [id])
  instanciaId    Int?
  instancia      Instancia?    @relation(fields: [instanciaId], references: [id])
  documentoId    Int?
  documento      Documento?    @relation(fields: [documentoId], references: [id])
  fechaInicio    DateTime?
  fechaLimite    DateTime?
  fechaFin       DateTime?
  diasParaVencer Int?
  numeroCis      String?
  codigoOperacion String?
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Documento {
  id             Int           @id @default(autoincrement())
  nombreArchivo  String
  tipoArchivo    String?
  urlArchivo     String?
  categoria      String?
  cursoId        Int?
  curso          Curso?        @relation(fields: [cursoId], references: [id])
  instanciaId    Int?
  instancia      Instancia?    @relation(fields: [instanciaId], references: [id])
  tareaId        Int?
  tarea          TareaOperativa? @relation(fields: [tareaId], references: [id])
  responsableId  Int?
  responsable    Responsable?   @relation(fields: [responsableId], references: [id])
  descripcion    String?
  fechaSubida    DateTime @default(now())
  etiquetas      String?
  createdAt      DateTime @default(now())
}

model Importacion {
  id                 Int     @id @default(autoincrement())
  nombreArchivo      String
  tipoArchivo        String?
  formato            String?
  hojaExcel          String?
  tipoImportacion    String
  estadoImportacion  EstadoImportacion @default(SUBIDO)
  totalFilas         Int?
  filasValidas       Int?
  filasDuplicadas    Int?
  filasAdvertencia   Int?
  filasRechazadas    Int?
  usuario            String?
  fechaImportacion   DateTime @default(now())
  resumen            String?
  createdAt          DateTime @default(now())
  filas              ImportacionFilaStaging[]
}

model ImportacionFilaStaging {
  id              Int               @id @default(autoincrement())
  importacionId   Int
  importacion     Importacion       @relation(fields: [importacionId], references: [id])
  archivoOrigen   String?
  hojaOrigen      String?
  filaOrigen      Int?
  tipoImportacion String
  rawPayload      String
  datosNormalizados String?
  estadoFila      EstadoFilaImportacion @default(VALIDA)
  advertencias    String?
  errores         String?
  posibleDuplicado Boolean @default(false)
  claveDuplicado  String?
  destinoTabla    String?
  destinoId       Int?
  createdAt       DateTime @default(now())
}

model AuditoriaEstadoCurso {
  id             Int       @id @default(autoincrement())
  cursoId        Int
  curso          Curso     @relation(fields: [cursoId], references: [id])
  estadoAnterior String?
  estadoNuevo    String
  usuario        String?
  fechaCambio    DateTime  @default(now())
  observaciones  String?
}

model ConversacionAsistente {
  id               Int       @id @default(autoincrement())
  titulo           String?
  tipoContexto     String?
  cursoId          Int?
  curso            Curso?   @relation(fields: [cursoId], references: [id])
  instanciaId      Int?
  instancia        Instancia? @relation(fields: [instanciaId], references: [id])
  tareaId          Int?
  tarea            TareaOperativa? @relation(fields: [tareaId], references: [id])
  responsableId    Int?
  responsable      Responsable? @relation(fields: [responsableId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  mensajes         MensajeAsistente[]
}

model MensajeAsistente {
  id               Int       @id @default(autoincrement())
  conversacionId   Int
  conversacion     ConversacionAsistente @relation(fields: [conversacionId], references: [id])
  rol              String
  contenido        String
  createdAt        DateTime @default(now())
}